generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  DOCTOR
  SUPER_ADMIN
}

enum AppModule {
  APPOINTMENTS
  PATIENTS
  INVENTORY
  CAJA
  AI_ASSISTANT
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users               User[]
  doctors             Doctor[]
  patients            Patient[]
  appointments        Appointment[]
  procedures          Procedure[]
  inventoryCategories InventoryCategory[]
  inventoryItems      InventoryItem[]
  cajaRecords         CajaRecord[]
  orgModules          OrgModule[]
}

model OrgModule {
  id             String       @id @default(cuid())
  organizationId String
  module         AppModule
  enabled        Boolean      @default(true)
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, module])
}

model DoctorModulePermission {
  id       String    @id @default(cuid())
  doctorId String
  module   AppModule
  enabled  Boolean   @default(true)
  doctor   Doctor    @relation(fields: [doctorId], references: [id])

  @@unique([doctorId, module])
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  hashedPassword      String
  name                String
  role                UserRole             @default(ADMIN)
  active              Boolean              @default(true)
  organizationId      String?
  totpSecret          String?
  totpEnabled         Boolean              @default(false)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  organization        Organization?        @relation(fields: [organizationId], references: [id])
  doctor              Doctor?              @relation("UserDoctor")
  passwordResetTokens PasswordResetToken[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Doctor {
  id                String                   @id @default(cuid())
  name              String
  specialty         String?
  phone             String?
  email             String?
  active            Boolean                  @default(true)
  organizationId    String
  userId            String?                  @unique
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  organization      Organization             @relation(fields: [organizationId], references: [id])
  user              User?                    @relation("UserDoctor", fields: [userId], references: [id])
  appointments      Appointment[]
  modulePermissions DoctorModulePermission[]
  clinicalNotes     ClinicalNote[]
}

model Procedure {
  id             String       @id @default(cuid())
  name           String
  description    String?
  cupsCode       String?
  active         Boolean      @default(true)
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])
  appointments   Appointment[]

  @@unique([name, organizationId])
}

model Patient {
  id               String           @id @default(cuid())
  firstName        String
  lastName         String
  idNumber         String
  phone            String
  email            String?
  birthDate        DateTime?
  address          String?
  guardianName     String?
  guardianRelation String?
  guardianPhone    String?
  habeaDataConsent Boolean          @default(false)
  organizationId   String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  organization     Organization     @relation(fields: [organizationId], references: [id])
  appointments     Appointment[]
  clinicalHistory  ClinicalHistory?
  cajaRecords      CajaRecord[]

  @@unique([idNumber, organizationId])
}

model Appointment {
  id             String       @id @default(cuid())
  patientId      String
  doctorId       String
  procedureId    String
  date           DateTime
  reminderJobId  String?
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  patient        Patient      @relation(fields: [patientId], references: [id])
  doctor         Doctor       @relation(fields: [doctorId], references: [id])
  procedure      Procedure    @relation(fields: [procedureId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])
}

model ClinicalHistory {
  id         String            @id @default(cuid())
  patientId  String            @unique
  background String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  patient    Patient           @relation(fields: [patientId], references: [id])
  notes      ClinicalNote[]
  odontogram OdontogramEntry[]
  files      PatientFile[]
}

model ClinicalNote {
  id                String          @id @default(cuid())
  clinicalHistoryId String
  doctorId          String
  type              NoteType
  content           String
  createdAt         DateTime        @default(now())
  clinicalHistory   ClinicalHistory @relation(fields: [clinicalHistoryId], references: [id])
  doctor            Doctor          @relation(fields: [doctorId], references: [id])
}

enum NoteType {
  INGRESO
  EVOLUCION
  PROCEDIMIENTO
  INTERCONSULTA
  EGRESO
}

model OdontogramEntry {
  id                String          @id @default(cuid())
  clinicalHistoryId String
  toothNumber       Int
  surface           Surface
  status            ToothStatus
  note              String?
  createdAt         DateTime        @default(now())
  clinicalHistory   ClinicalHistory @relation(fields: [clinicalHistoryId], references: [id])
}

enum Surface {
  OCLUSAL
  MESIAL
  DISTAL
  VESTIBULAR
  LINGUAL
}

enum ToothStatus {
  SANO
  CARIES
  OBTURACION
  CORONA
  ENDODONCIA
  IMPLANTE
  AUSENTE
  EXTRAIDO
  FRACTURA
}

model PatientFile {
  id                String          @id @default(cuid())
  clinicalHistoryId String
  name              String
  label             String?
  url               String
  mimeType          String
  createdAt         DateTime        @default(now())
  clinicalHistory   ClinicalHistory @relation(fields: [clinicalHistoryId], references: [id])
}

model InventoryItem {
  id             String            @id @default(cuid())
  commercialName String
  genericName    String?
  sku            String
  categoryId     String
  quantity       Decimal           @db.Decimal(10, 3)
  unit           InventoryUnit
  minStock       Decimal           @db.Decimal(10, 3)
  active         Boolean           @default(true)
  organizationId String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  category       InventoryCategory @relation(fields: [categoryId], references: [id])
  organization   Organization      @relation(fields: [organizationId], references: [id])
  stockLogs      StockLog[]

  @@unique([sku, organizationId])
}

model InventoryCategory {
  id             String        @id @default(cuid())
  name           String
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  items          InventoryItem[]

  @@unique([name, organizationId])
}

model StockLog {
  id          String        @id @default(cuid())
  itemId      String
  previousQty Decimal       @db.Decimal(10, 3)
  newQty      Decimal       @db.Decimal(10, 3)
  reason      String?
  createdAt   DateTime      @default(now())
  item        InventoryItem @relation(fields: [itemId], references: [id])
}

enum InventoryUnit {
  UNIDAD
  CAJA
  PAQUETE
  FRASCO
  TUBO
  ML
  G
}

model CajaRecord {
  id             String       @id @default(cuid())
  patientId      String
  description    String
  total          Decimal      @db.Decimal(10, 2)
  balance        Decimal      @db.Decimal(10, 2)
  status         CajaStatus
  invoiceId      String?
  invoiceNumber  String?
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  patient        Patient      @relation(fields: [patientId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])
  payments       Payment[]
}

model Payment {
  id           String        @id @default(cuid())
  cajaRecordId String
  amount       Decimal       @db.Decimal(10, 2)
  method       PaymentMethod
  createdAt    DateTime      @default(now())
  cajaRecord   CajaRecord    @relation(fields: [cajaRecordId], references: [id])
}

enum CajaStatus {
  PENDIENTE
  ABONO_PARCIAL
  PAGADO
}

enum PaymentMethod {
  EFECTIVO
  TRANSFERENCIA
  TARJETA_DEBITO
  TARJETA_CREDITO
}

// ── Audit Logging ──────────────────────────────────────────

enum AuditAction {
  LOGIN
  LOGOUT
  LOGIN_FAILED
  PATIENT_VIEWED
  PATIENT_CREATED
  PATIENT_UPDATED
  PATIENT_ANONYMIZED
  PATIENT_EXPORTED
  CLINICAL_NOTE_CREATED
  CLINICAL_NOTE_DELETED
  FILE_UPLOADED
  FILE_DELETED
}

model AuditLog {
  id             String      @id @default(cuid())
  userId         String
  userEmail      String
  action         AuditAction
  resource       String?
  resourceId     String?
  organizationId String?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime    @default(now())

  @@index([userId])
  @@index([organizationId, createdAt])
  @@index([action, createdAt])
}
