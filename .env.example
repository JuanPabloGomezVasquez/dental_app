# Base de Datos (PostgreSQL) — desarrollo
# Base de Datos para tests E2E (separada de desarrollo para evitar contaminación)
DATABASE_URL_TEST="postgresql://user:password@host:5432/dental-app-test?sslmode=require"

# Base de Datos (PostgreSQL)
# Opciones gratuitas: https://neon.tech o https://supabase.com
DATABASE_URL="postgresql://user:password@host:5432/dental-app?sslmode=require"

# Clave secreta para sesiones JWT (genera una con: openssl rand -base64 32)
SESSION_SECRET="tu-clave-secreta-de-32-caracteres-minimo"

# URL de la aplicación
NEXTAUTH_URL="http://localhost:3000"

# Cifrado de campos PII (genera con: openssl rand -hex 32)
FIELD_ENCRYPTION_KEY=

# Resend — envío de correos (bienvenida de doctores, recuperación de contraseña)
# 1. Crear cuenta en https://resend.com
# 2. Verificar el dominio desde el que se enviarán los correos
# 3. Crear un API Key con permisos "Sending access"
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Dirección del remitente — DEBE ser de un dominio verificado en Resend
FROM_EMAIL="DentApp <noreply@tudominio.com>"

# URL pública de la aplicación — usada en los links de recuperación de contraseña
# En desarrollo: http://localhost:3000
# En producción: https://tu-app.vercel.app (sin barra final)
APP_URL="http://localhost:3000"

# Vercel Blob — almacenamiento de archivos de historia clínica
# Obtener en: Vercel Dashboard → Storage → Blob → Create Store → BLOB_READ_WRITE_TOKEN
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxx

# Inngest — obtener en https://app.inngest.com
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# WhatsApp Business API — obtener en https://business.facebook.com/
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Nombre de la plantilla aprobada en Meta Business Manager
WHATSAPP_TEMPLATE_NAME=recordatorio_cita

# RIPS (Resolución 2275/2023)
NIT_CONSULTORIO=
RIPS_MUNICIPIO_CODE=
RIPS_COD_PRESTADOR=

# Siigo / Alegra — facturación electrónica
SIIGO_API_KEY=
SIIGO_ACCOUNT_ID=
